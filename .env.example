# === Server FQDN ===
SERVER_NAME=matrix.example.com

# === Tuwunel (Matrix homeserver) ===
TUWUNEL_PORT=6167
TUWUNEL_ALLOW_REGISTRATION=false
# Required when TUWUNEL_ALLOW_REGISTRATION is true. Clients must provide this token to register.
TUWUNEL_REGISTRATION_TOKEN=
TUWUNEL_TRUSTED_SERVERS=["matrix.org"]
TUWUNEL_LOG=warn
# Max upload file size in bytes (default: 20MB)
# TUWUNEL_MAX_REQUEST_SIZE=20971520
# Enable legacy unauthenticated media endpoints (for clients without authenticated media support)
# TUWUNEL_ALLOW_LEGACY_MEDIA=true

# === Traefik ===
ACME_EMAIL=admin@example.com

# Уровень логирования Traefik: DEBUG, INFO, WARN, ERROR, FATAL, PANIC
TRAEFIK_LOG_LEVEL=ERROR
